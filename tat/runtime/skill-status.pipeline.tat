// -----------------------------------------------------------------------------
// Requirement edges
// -----------------------------------------------------------------------------

heavyStrikeCardHasRequirementSummary := {
  heavyStrikeStatusCard : hasRequirementSummary : heavyStrikeRequirementSummary
}

powerSwingCardHasRequirementSummary := {
  powerSwingStatusCard : hasRequirementSummary : powerSwingRequirementSummary
}

shieldGuardCardHasRequirementSummary := {
  shieldGuardStatusCard : hasRequirementSummary : shieldGuardRequirementSummary
}

requirementSectionIncludesHeavyStrikeSummary := {
  skillRequirementSummarySection : includesRequirementSummary : heavyStrikeRequirementSummary
}

requirementSectionIncludesPowerSwingSummary := {
  skillRequirementSummarySection : includesRequirementSummary : powerSwingRequirementSummary
}

requirementSectionIncludesShieldGuardSummary := {
  skillRequirementSummarySection : includesRequirementSummary : shieldGuardRequirementSummary
}

// -----------------------------------------------------------------------------
// Explanation edges
// -----------------------------------------------------------------------------

heavyStrikeCardHasRenderableExplanation := {
  heavyStrikeStatusCard : hasRenderableExplanation : heavyStrikeRenderableExplanation
}

powerSwingCardHasRenderableExplanation := {
  powerSwingStatusCard : hasRenderableExplanation : powerSwingRenderableExplanation
}

shieldGuardCardHasRenderableExplanation := {
  shieldGuardStatusCard : hasRenderableExplanation : shieldGuardRenderableExplanation
}

explanationSectionIncludesHeavyStrikeExplanation := {
  skillExplanationSection : includesExplanation : heavyStrikeRenderableExplanation
}

explanationSectionIncludesPowerSwingExplanation := {
  skillExplanationSection : includesExplanation : powerSwingRenderableExplanation
}

explanationSectionIncludesShieldGuardExplanation := {
  skillExplanationSection : includesExplanation : shieldGuardRenderableExplanation
}

// -----------------------------------------------------------------------------
// Provenance edges
// -----------------------------------------------------------------------------

skillStatusViewReferencesCharacterGraph := {
  skillStatusViewRoot : referencesSemanticGraph : characterGraph
}

skillStatusViewReferencesStatsGraph := {
  skillStatusViewRoot : referencesSemanticGraph : statsGraph
}

skillStatusViewReferencesSkillsGraph := {
  skillStatusViewRoot : referencesSemanticGraph : skillsGraph
}

skillStatusViewReferencesUnlockRulesGraph := {
  skillStatusViewRoot : referencesSemanticGraph : unlockRulesGraph
}

// -----------------------------------------------------------------------------
// Skill status base graph
// -----------------------------------------------------------------------------

skillStatusBaseGraph := @seed(graph) {
  node: [
    skillStatusViewRoot,
    userSkillDefinitionsRoot,

    skillStatusCardsSection,
    skillRequirementSummarySection,
    skillExplanationSection,

    heavyStrikeStatusCard,
    powerSwingStatusCard,
    shieldGuardStatusCard,
    ironWallStatusCard,
    arcaneBoltStatusCard,
    spellSurgeStatusCard,
    wardingMindStatusCard,
    spellGuardStatusCard,
    quickStepStatusCard,
    initiativeStatusCard,
    preciseShotStatusCard,
    weaponMasteryStatusCard,

    heavyStrikeRequirementSummary,
    powerSwingRequirementSummary,
    shieldGuardRequirementSummary,

    heavyStrikeRenderableExplanation,
    powerSwingRenderableExplanation,
    shieldGuardRenderableExplanation,
  ],

  edge: [
    skillStatusViewIncludesCardsSection,
    skillStatusViewIncludesRequirementSummarySection,
    skillStatusViewIncludesExplanationSection,

    cardsSectionIncludesHeavyStrikeCard,
    cardsSectionIncludesPowerSwingCard,
    cardsSectionIncludesShieldGuardCard,
    cardsSectionIncludesIronWallCard,
    cardsSectionIncludesArcaneBoltCard,
    cardsSectionIncludesSpellSurgeCard,
    cardsSectionIncludesWardingMindCard,
    cardsSectionIncludesSpellGuardCard,
    cardsSectionIncludesQuickStepCard,
    cardsSectionIncludesInitiativeCard,
    cardsSectionIncludesPreciseShotCard,
    cardsSectionIncludesWeaponMasteryCard,

    heavyStrikeCardTargetsSkill,
    powerSwingCardTargetsSkill,
    shieldGuardCardTargetsSkill,
    ironWallCardTargetsSkill,
    arcaneBoltCardTargetsSkill,
    spellSurgeCardTargetsSkill,
    wardingMindCardTargetsSkill,
    spellGuardCardTargetsSkill,
    quickStepCardTargetsSkill,
    initiativeCardTargetsSkill,
    preciseShotCardTargetsSkill,
    weaponMasteryCardTargetsSkill,

    heavyStrikeCardHasStatus,
    powerSwingCardHasStatus,
    shieldGuardCardHasStatus,
    ironWallCardHasStatus,
    arcaneBoltCardHasStatus,
    spellSurgeCardHasStatus,
    wardingMindCardHasStatus,
    spellGuardCardHasStatus,
    quickStepCardHasStatus,
    initiativeCardHasStatus,
    preciseShotCardHasStatus,
    weaponMasteryCardHasStatus,

    heavyStrikeCardHasRequirementSummary,
    powerSwingCardHasRequirementSummary,
    shieldGuardCardHasRequirementSummary,

    requirementSectionIncludesHeavyStrikeSummary,
    requirementSectionIncludesPowerSwingSummary,
    requirementSectionIncludesShieldGuardSummary,

    heavyStrikeCardHasRenderableExplanation,
    powerSwingCardHasRenderableExplanation,
    shieldGuardCardHasRenderableExplanation,

    explanationSectionIncludesHeavyStrikeExplanation,
    explanationSectionIncludesPowerSwingExplanation,
    explanationSectionIncludesShieldGuardExplanation,

    skillStatusViewReferencesCharacterGraph,
    skillStatusViewReferencesStatsGraph,
    skillStatusViewReferencesSkillsGraph,
    skillStatusViewReferencesUnlockRulesGraph,
  ],

  meta: {
    purpose: "Expose skill status cards while receiving runtime facts through @inject.",
    owner: tat,
    targetConsumer: react,
    status: "pass_26_dynamic_requirement_sync_ready",
    boundary: "Runtime values enter through @inject. TAT actions derive card status and requirement display values.",
  },

  root: skillStatusViewRoot,
}

// -----------------------------------------------------------------------------
// Skill status interpreted graph
// -----------------------------------------------------------------------------

skillStatusInjectedGraph := skillStatusBaseGraph
  <- @inject(character_runtime_facts, ".tat")
  <- @inject(user_skill_definitions, ".tat")

skillStatusViewGraph := skillStatusInjectedGraph
  -> syncPowerSwingRequirement(skillStatusInjectedGraph)
  -> syncShieldGuardRequirement(skillStatusInjectedGraph)
  -> markPowerSwingReady(skillStatusInjectedGraph)
  -> markPowerSwingLearned(skillStatusInjectedGraph)
  -> markShieldGuardReady(skillStatusInjectedGraph)
  -> markShieldGuardLearned(skillStatusInjectedGraph)
  -> markIronWallReady(skillStatusInjectedGraph)
  -> markIronWallLearned(skillStatusInjectedGraph)
  -> markArcaneBoltReady(skillStatusInjectedGraph)
  -> markArcaneBoltLearned(skillStatusInjectedGraph)
  -> markSpellSurgeReady(skillStatusInjectedGraph)
  -> markSpellSurgeLearned(skillStatusInjectedGraph)
  -> markWardingMindReady(skillStatusInjectedGraph)
  -> markWardingMindLearned(skillStatusInjectedGraph)
  -> markSpellGuardReady(skillStatusInjectedGraph)
  -> markSpellGuardLearned(skillStatusInjectedGraph)
  -> markQuickStepReady(skillStatusInjectedGraph)
  -> markQuickStepLearned(skillStatusInjectedGraph)
  -> markInitiativeReady(skillStatusInjectedGraph)
  -> markInitiativeLearned(skillStatusInjectedGraph)
  -> markPreciseShotReady(skillStatusInjectedGraph)
  -> markPreciseShotLearned(skillStatusInjectedGraph)
  -> markWeaponMasteryReady(skillStatusInjectedGraph)
  -> markWeaponMasteryLearned(skillStatusInjectedGraph)

// -----------------------------------------------------------------------------
// Projection
// -----------------------------------------------------------------------------

skillStatusReactProjection := @project(graph) {
  source: skillStatusViewGraph,
  format: tree,
  include: [
    nodes,
    edges,
    root,
    meta,
  ],
  purpose: "Expose React-facing skill status cards from the injected runtime pipeline.",
}

skillStatusReactProjectionView := skillStatusViewGraph <> skillStatusReactProjection(skillStatusViewGraph)

// -----------------------------------------------------------------------------
// Exports
// -----------------------------------------------------------------------------

export {
  skillStatusViewRoot,
  skillStatusBaseGraph,
  skillStatusInjectedGraph,
  skillStatusViewGraph,
  skillStatusReactProjection,
  skillStatusReactProjectionView,

  heavyStrikeStatusCard,
  powerSwingStatusCard,
  shieldGuardStatusCard,
  ironWallStatusCard,
  arcaneBoltStatusCard,
  spellSurgeStatusCard,
  wardingMindStatusCard,
  spellGuardStatusCard,
  quickStepStatusCard,
  initiativeStatusCard,
  preciseShotStatusCard,
  weaponMasteryStatusCard,
}