// -----------------------------------------------------------------------------
// skill-status.pipeline.tat
// Character + Skill Builder
//
// Pass 26 goal:
// Keep runtime values raw, then let TAT own requirement syncing,
// status interpretation, and React-facing projection data.
//
// Python supplies raw runtime facts only.
// TAT owns semantic interpretation.
// React owns rendering.
// -----------------------------------------------------------------------------

import {
  characterBuilderRootGraph,
  runtimeDataContractGraph,

  characterGraph,
  statsGraph,
  skillsGraph,
  unlockRulesGraph,
  progressionNetwork,
  projectionGraph,

  strength,
  defense,
  intelligence,
  resistance,
  speed,
  dexterity,

  heavyStrike,
  powerSwing,
  shieldGuard,
  ironWall,
  arcaneBolt,
  spellSurge,
  wardingMind,
  spellGuard,
  quickStep,
  initiative,
  preciseShot,
  weaponMastery,

  locked,
  unlockable,
  unlocked,

  requirementMet,
  requirementUnmet,
} from "../character-builder.root.tat"

// -----------------------------------------------------------------------------
// Runtime fact injection
// -----------------------------------------------------------------------------

runtimeFactsRoot := <node {
  id: runtimeFactsRoot,
  label: "Runtime Facts",
  kind: runtimeFactsRoot,
  description: "Root node for Python-owned runtime facts injected into TAT.",
}>

userSkillDefinitionsRoot := <node {
  id: userSkillDefinitionsRoot,
  label: "User Skill Definitions",
  kind: userSkillDefinitionsRoot,
  description: "Root node for Python-owned user-created skill definitions injected into TAT.",
}>

runtimeFactsBaseGraph := @seed(graph) {
  node: [
    runtimeFactsRoot,
  ],

  edge: [
  ],

  meta: {
    purpose: "Base graph that receives Python-owned runtime facts through @inject.",
    owner: tat,
    sourceOwner: python,
    boundary: "Python supplies values only. TAT owns interpretation.",
  },

  root: runtimeFactsRoot,
}

// -----------------------------------------------------------------------------
// Pass 26 requirement sync actions
//
// These run before status interpretation.
// They keep requirement display values aligned with injected runtime facts.
// -----------------------------------------------------------------------------

syncPowerSwingRequirement := @action(graph) {
  ?> @query(state) {
    target: strength,
    key: current,
  }

  -> @update(node) {
    powerSwingRequirementSummary.actualValue = strength.current,
    powerSwingRequirementSummary.requiredValue = 12,
    powerSwingRequirementSummary.result = requirementUnmet,
    powerSwingRequirementSummary.displayResult = "Unmet",
    powerSwingRequirementSummary.summary = "Needs more Strength training. Required: 12. Current: " + strength.current + ".",
  }
}

syncShieldGuardRequirement := @action(graph) {
  ?> @query(state) {
    target: defense,
    key: current,
  }

  -> @update(node) {
    shieldGuardRequirementSummary.actualValue = defense.current,
    shieldGuardRequirementSummary.requiredValue = 8,
    shieldGuardRequirementSummary.result = requirementUnmet,
    shieldGuardRequirementSummary.displayResult = "Unmet",
    shieldGuardRequirementSummary.summary = "Needs more Defense training. Required: 8. Current: " + defense.current + ".",
  }
}

// -----------------------------------------------------------------------------
// Pass 25 / 26 dynamic interpretation actions
//
// Python injects raw values only.
// TAT decides Locked / Ready / Learned.
// -----------------------------------------------------------------------------

markPowerSwingReady := @action(graph) {
  ?> @query(state) {
    target: strength,
    key: current,
    value: >= 12,
  }

  ?> @query(state) {
    target: heavyStrike,
    key: learned,
    value: true,
  }

  ?> @query(state) {
    target: powerSwing,
    key: learned,
    value: false,
  }

  -> @update(node) {
    powerSwingStatusCard.status = unlockable,
    powerSwingStatusCard.displayStatus = "Ready",
    powerSwingStatusCard.summary = "Power Swing is ready to learn.",

    powerSwingRequirementSummary.result = requirementMet,
    powerSwingRequirementSummary.displayResult = "Met",
    powerSwingRequirementSummary.actualValue = strength.current,
    powerSwingRequirementSummary.requiredValue = 12,
    powerSwingRequirementSummary.summary = "Strength training is strong enough. Required: 12. Current: " + strength.current + ".",

    powerSwingRenderableExplanation.text = "Power Swing is ready to learn. Strength is high enough, and Heavy Strike has already been learned.",
  }
}

markPowerSwingLearned := @action(graph) {
  ?> @query(state) {
    target: powerSwing,
    key: learned,
    value: true,
  }

  -> @update(node) {
    powerSwingStatusCard.status = unlocked,
    powerSwingStatusCard.displayStatus = "Learned",
    powerSwingStatusCard.summary = "Power Swing has been learned.",

    powerSwingRequirementSummary.result = requirementMet,
    powerSwingRequirementSummary.displayResult = "Met",
    powerSwingRequirementSummary.actualValue = strength.current,
    powerSwingRequirementSummary.requiredValue = 12,
    powerSwingRequirementSummary.summary = "Strength training is strong enough. Required: 12. Current: " + strength.current + ".",

    powerSwingRenderableExplanation.text = "Power Swing has already been learned and is part of this character's skill set.",
  }
}

markShieldGuardReady := @action(graph) {
  ?> @query(state) {
    target: defense,
    key: current,
    value: >= 8,
  }

  ?> @query(state) {
    target: shieldGuard,
    key: learned,
    value: false,
  }

  -> @update(node) {
    shieldGuardStatusCard.status = unlockable,
    shieldGuardStatusCard.displayStatus = "Ready",
    shieldGuardStatusCard.summary = "Shield Guard is ready to learn.",

    shieldGuardRequirementSummary.result = requirementMet,
    shieldGuardRequirementSummary.displayResult = "Met",
    shieldGuardRequirementSummary.actualValue = defense.current,
    shieldGuardRequirementSummary.requiredValue = 8,
    shieldGuardRequirementSummary.summary = "Defense training is strong enough. Required: 8. Current: " + defense.current + ".",

    shieldGuardRenderableExplanation.text = "Shield Guard is ready to learn. Defense is high enough.",
  }
}

markShieldGuardLearned := @action(graph) {
  ?> @query(state) {
    target: shieldGuard,
    key: learned,
    value: true,
  }

  -> @update(node) {
    shieldGuardStatusCard.status = unlocked,
    shieldGuardStatusCard.displayStatus = "Learned",
    shieldGuardStatusCard.summary = "Shield Guard has been learned.",

    shieldGuardRequirementSummary.result = requirementMet,
    shieldGuardRequirementSummary.displayResult = "Met",
    shieldGuardRequirementSummary.actualValue = defense.current,
    shieldGuardRequirementSummary.requiredValue = 8,
    shieldGuardRequirementSummary.summary = "Defense training is strong enough. Required: 8. Current: " + defense.current + ".",

    shieldGuardRenderableExplanation.text = "Shield Guard has already been learned and is part of this character's skill set.",
  }
}

